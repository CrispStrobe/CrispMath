platform :osx, '10.15'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure \"flutter pub get\" is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run \"flutter pub get\""
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)
  end

  # Force-load every object file from the SymEngine static archive into the
  # Runner binary. The symbols are only reached via dart:ffi
  # DynamicLibrary.process() at runtime; without `-all_load` the linker
  # would happily drop them.
  #
  # Status:
  #   Debug — works. 45 flutter_symengine_* symbols land in
  #     `Contents/MacOS/crisp_calc.debug.dylib`.
  #   Release — broken. The C++ part of the static archive (`SymEngine::*`,
  #     thousands of mangled symbols) links fine, but the C wrapper
  #     `flutter_symengine_wrapper.o` is silently dropped. Tried adding
  #     `-Wl,-force_load,…` on the on-disk xcframework slice (duplicate
  #     symbols when combined with `-all_load`, missing symbols when
  #     alone) and patching the bridge POD's LIBRARY_SEARCH_PATHS (still
  #     drops the wrapper objects). The real fix lives in the bridge
  #     plugin: rework the podspec so the wrapper is its own static lib
  #     separate from SymEngine, or pre-link the framework binary
  #     properly. See PLAN.md P1#2.
  installer.aggregate_targets.each do |agg|
    agg.user_build_configurations.each_key do |config|
      xcconfig_path = agg.xcconfig_path(config)
      next unless File.exist?(xcconfig_path)
      contents = File.read(xcconfig_path)
      unless contents.include?('-all_load')
        new_contents = contents.gsub(
          /^(OTHER_LDFLAGS\s*=.*)$/,
          '\\1 -all_load',
        )
        File.write(xcconfig_path, new_contents)
      end
    end
  end
end
